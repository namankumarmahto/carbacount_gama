        ere1_0.custom_category_name,
        ere1_0.plant_id,
        ere1_0.recorded_at,
        ere1_0.scope,
        ere1_0.tenant_id,
        ere1_0.total_emission 
    from
        emission_record ere1_0 
    left join
        plant p1_0 
            on p1_0.id=ere1_0.plant_id 
    where
        ere1_0.tenant_id=? 
        and p1_0.id=?
